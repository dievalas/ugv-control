<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center">

    <!-- Kaire puse -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btnW"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="W"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnA"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="A"/>

            <Button
                android:id="@+id/btnX"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="X"/>

            <Button
                android:id="@+id/btnD"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="D"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnS"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="S"/>

    </LinearLayout>

    <!-- Desine puse -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btnI"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="I"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnJ"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="J"/>

            <Button
                android:id="@+id/btnO"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="O"/>

            <Button
                android:id="@+id/btnL"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="L"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnK"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="K"/>

    </LinearLayout>

</LinearLayout>